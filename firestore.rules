rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin helper — reads isAdmin flag from the user's own Firestore document.
    // No PII in rules. Managed via the admin panel (users/{uid}.isAdmin = true).
    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Invitation codes ────────────────────────────────────────────────
    match /invitationCodes/{codeId} {
      // get: allow unauthenticated read of a single code (needed for pre-login validation)
      // list: admin only — prevents enumeration of all codes
      allow get: if true;
      allow list: if isAdmin();
      // Only admin can create or delete codes
      allow create, delete: if isAdmin();
      // Any authenticated user can mark an available code as "used" (registration)
      // Field restriction: only status/usedBy/usedAt may change — prevents self-granting modules
      allow update: if (isAdmin())
                    || (request.auth != null
                        && resource.data.status == 'available'
                        && request.resource.data.status == 'used'
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['status', 'usedBy', 'usedAt']));
    }

    // ── Per-user data ────────────────────────────────────────────────────
    match /users/{userId} {
      // Admin can read/write all user documents (for module management)
      // Users can read/write their own document (but not delete it)
      allow read:          if isAdmin() || isOwner(userId);
      allow create, update: if isAdmin() || isOwner(userId);
      allow delete:         if isAdmin();

      match /purchases/{purchaseId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /market_cache/{cacheId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /marketData/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /watchlist/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /liveMetrics/{document} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /assistantConversations/{convId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /cache/{cacheId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /watchlistGroups/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Écrites par le Worker Enable Banking via l'API REST Firestore (compte de service,
      // bypass ces règles) ; lecture nécessaire côté client pour afficher les données.
      match /bankConnections/{connectionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /bankAccounts/{accountId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
